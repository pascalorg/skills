# Direct Provider API Keys — No Gateway
# Use this when your tool natively supports multiple providers (OpenCode, Aider)
# or when you only need a single provider.
#
# You don't need ALL of these. Pick the providers that match your infrastructure.
# Mix and match: e.g., Bedrock for Claude, Azure for GPT, direct for Gemini/Grok.

# ============================================================
# DIRECT PROVIDERS — API keys from each provider
# ============================================================

# Anthropic (Claude models — planning, review, visual analysis)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT models — code implementation)
OPENAI_API_KEY=sk-...

# Google AI (Gemini models — research, math, science)
GOOGLE_API_KEY=...

# xAI (Grok models — adversarial review)
XAI_API_KEY=...

# ============================================================
# AMAZON BEDROCK — Claude, Amazon Nova, Mistral, Llama via AWS
# ============================================================
# Use instead of ANTHROPIC_API_KEY to bill Claude through AWS.
# Also gives access to Amazon Nova as a different model family.

# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
#
# Or use AWS SSO / IAM role (no keys needed if running on AWS):
# AWS_PROFILE=your-sso-profile
#
# Bedrock model IDs:
#   bedrock/anthropic.claude-opus-4-6-v1
#   bedrock/anthropic.claude-sonnet-4-5-v1
#   bedrock/anthropic.claude-sonnet-4-6-v1
#   bedrock/anthropic.claude-haiku-4-5-v1
#   bedrock/amazon.nova-pro-v1
#   bedrock/amazon.nova-lite-v1
#   bedrock/meta.llama-4-maverick-17b-128e-instruct-v1

# ============================================================
# MICROSOFT AZURE OPENAI — GPT, Claude via Azure
# ============================================================
# Use instead of OPENAI_API_KEY to bill GPT through Azure.
# Claude available via Azure AI Foundry.

# AZURE_API_KEY=...
# AZURE_RESOURCE_NAME=your-resource-name
# AZURE_DEPLOYMENT_NAME=your-deployment-name
# AZURE_API_VERSION=2024-12-01-preview
#
# Or use Azure AD / managed identity (no API key needed):
# AZURE_AD_TOKEN=...
#
# Azure model IDs (depend on your deployment names):
#   azure/gpt-5.4
#   azure/gpt-5.2
#   azure/gpt-4o
#   azure/claude-opus-4-6          (via AI Foundry)
#   azure/claude-sonnet-4-5        (via AI Foundry)

# ============================================================
# GOOGLE VERTEX AI — Gemini, Claude via GCP
# ============================================================
# Use instead of GOOGLE_API_KEY to bill Gemini through GCP.
# Claude available via Model Garden.

# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GOOGLE_CLOUD_REGION=us-central1
#
# Vertex model IDs:
#   vertex/gemini-3.1-pro
#   vertex/gemini-3-pro
#   vertex/gemini-3-flash
#   vertex/claude-opus-4-6         (via Model Garden)
#   vertex/claude-sonnet-4-5       (via Model Garden)

# ============================================================
# OTHER PROVIDERS
# ============================================================

# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...
# GROQ_API_KEY=...

# ============================================================
# CUSTOM ENDPOINTS (only set if using non-default base URLs)
# ============================================================

# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_BASE_URL=https://api.openai.com/v1
# XAI_BASE_URL=https://api.x.ai/v1
