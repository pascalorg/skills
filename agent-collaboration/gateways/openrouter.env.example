# OpenRouter Gateway Configuration
# Single API key for 100+ models from all providers.
# Get your key at https://openrouter.ai/keys
#
# OpenRouter handles provider routing automatically.
# You don't need Anthropic, OpenAI, Google, or xAI keys —
# OpenRouter proxies to all of them with a single key.

OPENROUTER_API_KEY=sk-or-...

# OpenRouter endpoint (OpenAI-compatible)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================
# MODEL IDS — use provider/model format
# ============================================================
#
# Direct provider models (routed via OpenRouter):
#   anthropic/claude-opus-4-6       — Planning, review
#   openai/gpt-5.4                  — Code implementation
#   google/gemini-3.1-pro           — Research, math
#   google/gemini-3-pro             — Science, math
#   xai/grok-4                      — Adversarial review
#   openai/gpt-4o                   — Peer review (fallback)
#
# OpenRouter also supports specifying provider preferences
# in the request body to force routing through specific
# infrastructure (e.g., Bedrock, Azure):
#
#   "provider": {
#     "order": ["Amazon Bedrock", "Anthropic"],
#     "allow_fallbacks": true
#   }
#
# This routes Claude requests through Bedrock first,
# falling back to Anthropic direct if Bedrock is unavailable.

# ============================================================
# OPTIONAL: Direct provider keys for fallback
# ============================================================
# If you also want direct provider access alongside OpenRouter:
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...
# XAI_API_KEY=...
#
# AWS credentials (if using Bedrock via OpenRouter provider routing):
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
