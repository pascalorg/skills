# Vercel AI Gateway Configuration
# Zero token markup, 40+ providers, managed infrastructure
# Enable at: https://vercel.com/{team}/{project}/settings → AI Gateway

# Option 1: OIDC Auth (Recommended — automatic token management)
# Run: vercel link && vercel env pull .env.local
# This provisions VERCEL_OIDC_TOKEN automatically. No manual key needed.

# Option 2: Manual API Key (for CI or non-Vercel environments)
AI_GATEWAY_API_KEY=...

# Vercel AI Gateway endpoint (OpenAI-compatible)
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Model IDs use provider/model format (dots for versions in Vercel AI Gateway):
# anthropic/claude-opus-4.6     — Planning, review
# openai/gpt-5.4               — Code implementation
# google/gemini-3.1-pro         — Research, math
# google/gemini-3-pro           — Science, math
# xai/grok-4                    — Adversarial review

# Route Claude Code through AI Gateway for observability:
# ANTHROPIC_BASE_URL=https://ai-gateway.vercel.sh
# ANTHROPIC_AUTH_TOKEN=your-vercel-ai-gateway-api-key
# ANTHROPIC_API_KEY=""  # Must be empty string
